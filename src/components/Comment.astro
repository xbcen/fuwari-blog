---
import '../styles/comment.css';

const commentEnvId = 'https://pl.xbcen.dpdns.org/';  // envid配置
const { path } = Astro.props;
---

<div id="tcomment" data-path={path}></div>

<script define:vars={{ commentEnvId }}>
  // 封装初始化函数
  function initTwikoo() {
    const container = document.getElementById("tcomment");
    if (!container) return;

    // 如果脚本还没加载，则动态加载
    if (typeof twikoo === 'undefined') {
      const script = document.createElement("script");
      script.src = "https://registry.npmmirror.com/twikoo/1.7.14/files/dist/twikoo.min.js";
      script.async = true;
      script.onload = () => {
        executeInit(container);
      };
      document.body.appendChild(script);
    } else {
      executeInit(container);
    }
  }

  function executeInit(container) {
    const path = container.dataset.path || window.location.pathname;
    twikoo.init({
      envId: commentEnvId,
      el: '#tcomment',
      path: path,
    });
    
    fetchCommentsCount(path);
  }

  // 评论数获取
  function fetchCommentsCount(path) {
    if (typeof twikoo === "undefined") return;
    
    twikoo.getCommentsCount({
      envId: commentEnvId,
      urls: [path],
      includeReply: true,
    }).then(res => {
      const placeholder = document.getElementById("twikoo-comment-count-placeholder");
      if (placeholder && res.length > 0) {
        placeholder.textContent = res[0].count;
      }
    }).catch(err => console.error("Twikoo Count Error:", err));
  }

  initTwikoo();

  document.addEventListener("astro:after-swap", initTwikoo);
</script>